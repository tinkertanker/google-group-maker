# Google Group Maker - Environment Variables
# Copy this file to .env and fill in the values

# Required: Your default email address
DEFAULT_EMAIL=your-email@tinkertanker.com

# Optional: Admin email for API delegation (defaults to DEFAULT_EMAIL)
ADMIN_EMAIL=your-email@tinkertanker.com

# Optional: Default domain for groups
GOOGLE_GROUP_DOMAIN=tinkertanker.com

# Service Account Credentials (choose one method):
# Option 1: JSON string (for cloud deployments like Streamlit Cloud)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Option 2: File path (for local development)
# Place service-account-credentials.json in project root

# =============================================
# Web App Only (FastAPI) - OAuth Configuration
# =============================================

# Google OAuth credentials (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Optional: Restrict login to specific domain (e.g., tinkertanker.com)
ALLOWED_DOMAIN=

# Session secret - generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-in-production
